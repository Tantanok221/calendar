{
  "name": "calendar-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "A Bun monorepo for the Calendar desktop app and future packages",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "bun test",
    "typecheck": "bun run --cwd apps/desktop typecheck",
    "start": "bun run --cwd apps/desktop start",
    "dev": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/desktop build",
    "postinstall": "bun run --cwd apps/desktop postinstall",
    "build:unpack": "bun run --cwd apps/desktop build:unpack",
    "build:win": "bun run --cwd apps/desktop build:win",
    "build:mac": "bun run --cwd apps/desktop build:mac",
    "build:linux": "bun run --cwd apps/desktop build:linux"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4"
  }
}
